//calc required change in one point for one collider
float3 RequiredChange(int sdfId, float3 pointPosition, float3 pointDir)
{
    float4 newRot = HamiltonProduct(_boneRotationBuffer[sdfId], _sdfData[sdfId*3]); //new sdf rotation
    float4 rotationChange = HamiltonProduct(_boneRotationBuffer[sdfId], ConjugateQuaternion(_originalBonesRotation[sdfId])); //change of rotation from original to new
    float3 newPos = RotateByQuaternion(_sdfData[sdfId*3+1].xyz, rotationChange); //new sdf position
    newPos = newPos + _bonePositionBuffer[sdfId];
    //rotate sdf and point to be in world space base
    pointPosition = pointPosition - newPos;
    
    pointPosition = RotateByQuaternion(pointPosition, ConjugateQuaternion(newRot)); //this move point to sdf local space, but with world rotation, so we can use sdf parameters
    //point position in sdf origin
    
    float segmentLength = length(pointDir);
    pointDir = normalize(pointDir);
   //bacuse the capsule have 2 radis the same, I could simplify this to ellipse
    float cosine = dot(pointPosition, pointDir) / length(pointPosition);//calcualting cosine between segment direction(longer radiuse) and direction between centers
    float capsuleDist = abs(sqrt(1 - pow(cosine, 2)) * length(segmentLength) + cosine * _strandRadius); //distance inside segment capsule in direction to object capsule
    
    float3 dir = normalize(pointPosition);
    float dist = 1 - length(pointPosition / _sdfData[sdfId*3+2].xyz) - capsuleDist; //ratio of how far in each axis point is(this scale me from ellipsoid to sphere)
    
    dist = clamp(dist, 0, 1);
    dir *= _sdfData[sdfId*3+2].xyz;
    dir = RotateByQuaternion(dir, newRot);
    
    return dir * dist;
}

//old version
[numthreads(32, 1, 1)] //strand id's
void CalcCollisions(uint3 id : SV_DispatchThreadID)
{
    if (id.x < _strands)
    {
        for (int i = 0; i < 1; i++)
        {
            for (int segment = 0; segment < _segmentsCount+1; segment++)
            {
                int pointId = id.x + segment * _strands;
                int cellId = ToCell(_PointData[pointId * 2]);
                uint mask = _MaskGrid[cellId].x;
                int sdfId = firstbithigh(mask);
                while (sdfId >= 0)
                {
                    //float3 dir = _PointData[(pointId + _strands) * 2] - _PointData[pointId * 2];
                    float3 changeVector = ChangeInPoint(_PointData[pointId * 2], sdfId);
                    _PointData[pointId * 2] += changeVector * clamp(segment, 0, 1);
                   // _PointData[(pointId + _strands) * 2] += changeVector;
                    mask &= ~(1u << sdfId);
                    sdfId = firstbithigh(mask);
                }
                mask = _MaskGrid[cellId].y;
                sdfId = firstbithigh(mask);
                while (sdfId >= 0)
                {
                    //float3 dir = _PointData[(pointId + _strands) * 2] - _PointData[pointId * 2];
                    float3 changeVector = ChangeInPoint(_PointData[pointId * 2], sdfId+32);
                    _PointData[pointId * 2] += changeVector * clamp(segment, 0, 1);
                    //_PointData[(pointId + _strands) * 2] += changeVector;
                    mask &= ~(1u << sdfId);
                    sdfId = firstbithigh(mask);
                }
            }
        }
    }
}



[numthreads(32,1,1)]
void ClearCollisions(uint3 id : SV_DispatchThreadID)
{
    _collisionConstraints[id.x] = float4(0, 0, 0, 0);
}