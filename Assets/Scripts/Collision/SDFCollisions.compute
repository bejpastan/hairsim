// Each #kernel tells which function to compile; you can have many kernels
#pragma kernel PreprocessSDF
#pragma kernel ClearMask
#pragma kernel CalcCollisions
#pragma kernel ClearCollisions

#include "../Math/Math.compute"


// Create a RenderTexture with enableRandomWrite flag and set it
// with cs.SetTexture
//RWStructuredBuffer<float4> _sdfRottationsBuffer;//this is static
//RWStructuredBuffer<float3> _sdfOffsetesBuffer; //this is static
//RWStructuredBuffer<float3> _sdfParametersBuffer;//this is static, SDF radiuses

RWStructuredBuffer<float4> _sdfData; //+0 rotation, +1 offset, +2 parameters
int _sdfCount;

RWStructuredBuffer<float3> _bonePositionBuffer;
RWStructuredBuffer<float4> _boneRotationBuffer;
RWStructuredBuffer<float4> _originalBonesRotation;//this is static
RWStructuredBuffer<float4> _collisionConstraints;


RWStructuredBuffer<uint2> _MaskGrid;//I count cells from bottom left corner, support up to 64 SDFs
float3 _gridOrigin;//bottom left front corner of grid
float _cellSize;
int3 _gridSizes;


int _strands;
float _strandRadius;
int _pointCount;
int _segmentsCount;
float _segmentLength;
RWStructuredBuffer<float3> _PointData; //velocities +1, predicted positions +0


float4x4 QuaternionToMatrix(float4 q)
{
    q = normalize(q);
    float4x4 rotationMatrix = float4x4
    (
        1 - 2 * ((q.y * q.y) + (q.z * q.z)), 2 * (q.x * q.y - q.z * q.w), 2 * (q.x * q.z + q.y * q.w), 0,
        2 * ((q.x * q.y) + (q.z * q.w)), 1 - 2 * (q.x * q.x + q.z * q.z), 2 * (q.y * q.z - q.x * q.w), 0,
        2 * ((q.x * q.z) + (q.y * q.w)), 2 * (q.z * q.y - q.x * q.w), 1 - 2 * (q.x * q.x + q.y * q.y), 0,
        0, 0, 0, 1
    );
    return rotationMatrix;
}

//return id of cell in _MaskGrid buffer, if outside of range return -1
int ToCell(float3 position)
{
    position = position - _gridOrigin;
    position = round(position / _cellSize);
    
    int id = position.x + (position.y * _gridSizes.x) + (position.z * _gridSizes.x * _gridSizes.y);
    
    if(position.x>_gridSizes.x || position.y>_gridSizes.y || position.z>_gridSizes.z || position.x<0 || position.y<0 || position.z<0)
    {
        id = -1;
    }
    else
    {
        id = max(id, -1);
    }
    
    return id; //if outside return -1;
}

void ChangeBit(int sdfId, int cellId)
{
    uint component = sdfId / 32;
    sdfId = sdfId % 32;
    _MaskGrid[cellId][component] |= (1u << sdfId);
}

void MaskCells(int sdfId, float3 newPos, float4 newRot)
{           
    float4x4 elipsoidMatrix = float4x4(
        _sdfData[sdfId*3+2].x, 0, 0, 0,
        0, _sdfData[sdfId*3+2].y, 0, 0,
        0, 0, _sdfData[sdfId*3+2].z, 0,
        0, 0, 0,                                    1
    );
    float4x4 rotationM = QuaternionToMatrix(newRot);
    elipsoidMatrix = mul(rotationM, elipsoidMatrix);
    
    elipsoidMatrix[0].w = newPos.x;
    elipsoidMatrix[1].w = newPos.y;
    elipsoidMatrix[2].w = newPos.z;
    
    float minWidth = elipsoidMatrix[0].w - sqrt(pow(elipsoidMatrix[0].x, 2) + pow(elipsoidMatrix[0].y, 2) + pow(elipsoidMatrix[0].z, 2));
    float maxWidth = elipsoidMatrix[0].w + sqrt(pow(elipsoidMatrix[0].x, 2) + pow(elipsoidMatrix[0].y, 2) + pow(elipsoidMatrix[0].z, 2));

    float minHeight = elipsoidMatrix[1].w - sqrt(pow(elipsoidMatrix[1].x, 2) + pow(elipsoidMatrix[1].y, 2) + pow(elipsoidMatrix[1].z, 2));
    float maxHeight = elipsoidMatrix[1].w + sqrt(pow(elipsoidMatrix[1].x, 2) + pow(elipsoidMatrix[1].y, 2) + pow(elipsoidMatrix[1].z, 2));

    float minThicknes = elipsoidMatrix[2].w - sqrt(pow(elipsoidMatrix[2].x, 2) +  pow(elipsoidMatrix[2].y, 2) + pow(elipsoidMatrix[2].z, 2));
    float maxThicknes = elipsoidMatrix[2].w + sqrt(pow(elipsoidMatrix[2].x, 2) + pow(elipsoidMatrix[2].y, 2) + pow(elipsoidMatrix[2].z, 2));
    
    //t - top, d-bottom/down
    //l-left, r-right
    //b-back, f-front
    int cellId = 0;
    cellId = ToCell(newPos);
    if (cellId >= 0)
    {
        ChangeBit(sdfId, cellId);
    }
    float3 tlb = float3(minWidth, maxHeight, maxThicknes);
    cellId = ToCell(tlb);
    if (cellId >= 0)
    {
        ChangeBit(sdfId, cellId);
    }
    float3 tlf = float3(minWidth, maxHeight, minThicknes);
    cellId = ToCell(tlf);
    if (cellId >= 0)
    {
        ChangeBit(sdfId, cellId);
    }
    float3 trf = float3(maxWidth, maxHeight, minThicknes);
    cellId = ToCell(trf);
    if (cellId >= 0)
    {
        ChangeBit(sdfId, cellId);
    }
    float3 trb = float3(maxWidth, maxHeight, maxThicknes);
    cellId = ToCell(trb);
    if (cellId >= 0)
    {
        ChangeBit(sdfId, cellId);
    }
    float3 dlb = float3(minWidth, minHeight, maxThicknes);
    cellId = ToCell(dlb);
    if (cellId >= 0)
    {
        ChangeBit(sdfId, cellId);
    }
    float3 dlf = float3(minWidth, minHeight, minThicknes);
    cellId = ToCell(dlf);
    if (cellId >= 0)
    {
        ChangeBit(sdfId, cellId);
    }
    float3 drf = float3(maxWidth, minHeight, minThicknes);
    cellId = ToCell(drf);
    if (cellId >= 0)
    {
        ChangeBit(sdfId, cellId);
    }
    float3 drb = float3(maxWidth, minHeight, maxThicknes);
    cellId = ToCell(drb);
    if (cellId >= 0)
    {
        ChangeBit(sdfId, cellId);
    }
}

float3 ChangeInPoint(float3 pointPos, uint sdfId)
{
    float4 newRot = HamiltonProduct(_boneRotationBuffer[sdfId], _sdfData[sdfId * 3]); //new sdf rotation
    float4 rotationChange = HamiltonProduct(_boneRotationBuffer[sdfId], ConjugateQuaternion(_originalBonesRotation[sdfId])); //change of rotation from original to new
    float3 newPos = RotateByQuaternion(_sdfData[sdfId * 3 + 1].xyz, rotationChange); //new sdf position
    newPos = newPos + _bonePositionBuffer[sdfId];
    
    float3 pointPosition = pointPos - newPos;
    
    pointPosition = RotateByQuaternion(pointPosition, ConjugateQuaternion(newRot)); //this move point to sdf local space, so we can use sdf parameters
    float3 sdfParams = _sdfData[sdfId * 3 + 2];
    float3 gradient = normalize(pointPosition / (sdfParams * sdfParams));
    
    float k0 = length(pointPosition / sdfParams);
    float k1 = length(pointPosition / (sdfParams * sdfParams));
    float distance = k0 * (k0 - 1.0) / k1;
    distance = min(0, distance);
    distance *= -1;
    
    //I need to add distance from center to edge of segment
    //float cosine = dot(gradient, direction);
    //float capsuleDist = abs(sqrt(1 - pow(cosine, 2)) * length(segmentLength) + cosine * _strandRadius);
    //distance = capsuleDist - distance;//positive is inside, negative is outside
    gradient = RotateByQuaternion(gradient, newRot);
    return (gradient * distance);
    
    
    float3 dir = normalize(pointPosition);
    float dist = 1 - length(pointPosition / _sdfData[sdfId * 3 + 2].xyz);
    
    
    dist = clamp(dist, 0, 1);
    dir *= _sdfData[sdfId * 3 + 2].xyz;
    dir = RotateByQuaternion(dir, newRot);
    
    return dir * dist;
}

//make sum of changes for one contact point
//contact point is in world space
float3 SummarizeChangesInPoint(float3 contactPoint, uint2 mask)
{
    uint localMask = mask.x;
    int sdfId = firstbithigh(localMask);
    int divider = 0;
    float3 changeSum = float3(0, 0, 0);
    while (sdfId >= 0)
    {
        float3 change = ChangeInPoint(contactPoint, sdfId);
        divider += exp(length(change));
        changeSum += change * exp(length(change));
        localMask &= ~(1u << sdfId);
        sdfId = firstbithigh(localMask);
    }
    localMask = mask.y;
    sdfId = firstbithigh(localMask);
    while (sdfId >= 0)
    {
        float3 change = ChangeInPoint(contactPoint, sdfId);
        divider += exp(length(change));
        changeSum += change * exp(length(change));
        localMask &= ~(1u << sdfId);
        sdfId = firstbithigh(localMask);
    }
    
    if(divider==0)
    {
        divider = 1;
    }
    
    return changeSum/divider;
}

//search contact point between collider and point, return closes point
//all data must be in local sdf space
float3 SdfContactPoint(float3 sdfParams, float3 pointPos, float3 direction, float segmentLength)
{
    float3 gradient = normalize(pointPos / (sdfParams * sdfParams));
    
    float k0 = length(pointPos / sdfParams);
    float k1 = length(pointPos / (sdfParams * sdfParams));
    float distance = k0 * (k0 - 1.0) / k1;
    
    //I need to add distance from center to edge of segment
    //float cosine = dot(gradient, direction);
    //float capsuleDist = abs(sqrt(1 - pow(cosine, 2)) * length(segmentLength) + cosine * _strandRadius);
    //distance = capsuleDist - distance;//positive is inside, negative is outside
    float3 contactPoint = pointPos - (gradient * distance);
    return contactPoint;
}

//calc sum of all changes for one ellipsoid
float3 SummarizedChange(uint2 mask, float3 originalPosition, float3 originalDirection)
{
    //iterate over all sdf's on one cell(mask)
    uint localMask = mask.x;
    int sdfId = firstbithigh(localMask);
    float segmentLength = length(originalDirection);
    float3 pointDir = normalize(originalDirection);
    float3 segmentCenter = originalPosition + pointDir * segmentLength * 0.5;
    float3 changeSum = float3(0, 0, 0);
    float divider = 0;
    while(sdfId>=0)
    {
        //precalculating data
            float4 newSdfRotation = HamiltonProduct(_boneRotationBuffer[sdfId], _sdfData[sdfId * 3]);
            float4 rotationChange = HamiltonProduct(_boneRotationBuffer[sdfId], ConjugateQuaternion(_originalBonesRotation[sdfId]));
            float3 newPos = RotateByQuaternion(_sdfData[sdfId * 3 + 1].xyz, rotationChange);
            newPos = newPos + _bonePositionBuffer[sdfId];
            //point in local sdf space
            float3 pointPosition = originalPosition - newPos;
            pointPosition = RotateByQuaternion(pointPosition, ConjugateQuaternion(newSdfRotation));
            float3 currentDir = normalize(RotateByQuaternion(pointDir, ConjugateQuaternion(newSdfRotation)));
            float3 currentCenter = RotateByQuaternion(segmentCenter - newPos, ConjugateQuaternion(newSdfRotation));
        //end pracalculation
        
        //get contactPoint in one sdf
        //float3 currentContact = SdfContactPoint(_sdfData[sdfId*3+2].xyz, currentCenter, currentDir, segmentLength);
        //currentContact = RotateByQuaternion(currentContact.xyz, newSdfRotation) + newPos; //back to world space
        //to this moment works
        
        //iterate over all sdf's
        float3 change = SummarizeChangesInPoint(segmentCenter.xyz, mask);
        
        float weight = exp(length(change));
        //changeSum += weight * change;//k is 1, so skipped
        changeSum += change; //k is 1, so skipped
        divider += weight;
        
        mask &= ~(1u << sdfId);
        sdfId = firstbithigh(mask);
    }
    
    localMask = mask.y;
    sdfId = firstbithigh(localMask);
    while (sdfId >= 0)
    {
        sdfId += 32; //to compensate for second mask
        //precalculating data
        float4 newSdfRotation = HamiltonProduct(_boneRotationBuffer[sdfId], _sdfData[sdfId * 3]);
        float4 rotationChange = HamiltonProduct(_boneRotationBuffer[sdfId], ConjugateQuaternion(_originalBonesRotation[sdfId]));
        float3 newPos = RotateByQuaternion(_sdfData[sdfId * 3 + 1].xyz, rotationChange);
        newPos = newPos + _bonePositionBuffer[sdfId];
            //point in local sdf space
        float3 pointPosition = originalPosition - newPos;
        pointPosition = RotateByQuaternion(pointPosition, ConjugateQuaternion(newSdfRotation));
        float3 currentDir = normalize(RotateByQuaternion(pointDir, ConjugateQuaternion(newSdfRotation)));
        float3 currentCenter = RotateByQuaternion(segmentCenter - newPos, ConjugateQuaternion(newSdfRotation));
        //end pracalculation
        
        //get contactPoint in one sdf
        float3 currentContact = SdfContactPoint(_sdfData[sdfId * 3 + 2].xyz, currentCenter, currentDir, segmentLength);
        currentContact = RotateByQuaternion(currentContact.xyz, newSdfRotation) + newPos; //back to world space
        
        
        //iterate over all sdf's
        float3 change = SummarizeChangesInPoint(currentContact.xyz, mask);
        float weight = exp(length(change));
        changeSum += change; //k is 1, so skipped
        //changeSum += weight * change; //k is 1, so skipped
        divider += weight;
        
        mask &= ~(1u << sdfId);
        sdfId = firstbithigh(mask);
    }
    
    return float3(changeSum);
    
    if(divider==0)
    {
        return float3(0, 0, 0);
    }
    else
    {
        return changeSum / divider;
    }
}

[numthreads(32, 1, 1)]
void PreprocessSDF(uint3 id : SV_DispatchThreadID)
{
    if (id.x < _sdfCount)
    {
        float4 newRot = HamiltonProduct(_boneRotationBuffer[id.x], _sdfData[id.x * 3]);
        float4 rotationChange = HamiltonProduct(_boneRotationBuffer[id.x], ConjugateQuaternion(_originalBonesRotation[id.x]));
        float3 newPos = RotateByQuaternion(_sdfData[id.x * 3 + 1].xyz, rotationChange);
        newPos = newPos + _bonePositionBuffer[id.x];
        MaskCells(id.x, newPos, newRot);
    }
}

[numthreads(32, 1, 1)]
void ClearMask(uint3 id : SV_DispatchThreadID)
{
    if (id.x < _gridSizes.x * _gridSizes.y * _gridSizes.z)
    {
        _MaskGrid[id.x] = 0;
    }
}


